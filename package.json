{
    "name": "tauri-app",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "check": "pnpm run knip && pnpm run format:ts:check && pnpm run lint:ts && pnpm run typecheck && pnpm test:ci && pnpm run build && pnpm run lint:rust && pnpm run format:rust",
        "dev": "vite",
        "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
        "format:ts": "oxfmt",
        "format:ts:check": "oxfmt --check",
        "knip": "knip",
        "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml",
        "lint:ts": "oxlint",
        "preview": "vite preview",
        "start": "tauri dev",
        "tauri": "tauri",
        "test": "vitest",
        "test:ci": "vitest --run",
        "typecheck": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@tanstack/vue-table": "^8.21.3",
        "@tanstack/vue-virtual": "^3.13.23",
        "@tauri-apps/api": "^2",
        "@tauri-apps/plugin-dialog": "^2.6.0",
        "@tauri-apps/plugin-fs": "^2.4.5",
        "@tauri-apps/plugin-sql": "^2.3.2",
        "fast-xml-parser": "^5.5.9",
        "pinia": "^3.0.4",
        "vue": "^3.5.31",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@pinia/testing": "^1.0.3",
        "@tauri-apps/cli": "^2",
        "@testing-library/user-event": "^14.6.1",
        "@testing-library/vue": "^8.1.0",
        "@types/node": "^25.5.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "jsdom": "^29.0.1",
        "knip": "^6.0.6",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.57.0",
        "typescript": "~6.0.2",
        "vite": "^6.0.3",
        "vitest": "^4.1.2",
        "vue-tsc": "^3.2.6"
    }
}
